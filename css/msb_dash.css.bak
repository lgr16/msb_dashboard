	@media (min-width: 1300px) {
		.container{
			max-width: 1300px;
		}
	}

	.visitsFilter {
		display: block;
		align-items: center;
		vertical-align: middle;
		margin:5px;
		padding: 5px;			
		overflow: visible;			
		line-height: 1.4;
	}

	.visitsFilter label {
		vertical-align: bottom;
	}



	#rt-filler, #standard_filter {
		min-height: 60px;
		background-color: #C6DEFF ;
		align-items: center;
		vertical-align: middle;
		
		margin-bottom: 5px;	
	}

	.visitsFilter .google-visualization-controls-categoryfilter-selected li {
		background-color: lightblue;
		padding: 6px;
		margin:2px;
	}

	#date {
		padding-bottom: 6px;
	}

	.chart {
		width: 100%; 
		min-height: 450px;
	}

	#standard_div .google-visualization-table-td {
		max-width: 250px;
	}
	
	.google-visualization-table td {
		vertical-align: middle;
		text-align: center;
	}
	
	#dateSalesRefresh, #dateVisitsPerson, 
	#dateSalesPerson, #date, #dateStandardRefresh {
		display: none;
	}
	h4 {
		padding:20px;
	}
	
	#hdb-refresh-timer {
		font-size: 0.75rem;
		margin: 0, 10px;
	}
	
	#hdb-refresh-btn, #hdb-refresh-btn:visited {
		margin-right: 5px;
		border-radius: unset;
		border-color: var(--e-global-color-accent);
		color: var(--e-global-color-secondary);
		background-color: var(--e-global-color-accent);
		padding: 12px 20px;
	}

	#hdb-refresh-btn:hover {		
		border-color: var(--e-global-color-secondary);
		color: var(--e-global-color-accent);
		background-color: var(--e-global-color-secondary);
		padding: 12px 20px;
	}
	

	#hdb-allProducts, #hdb-Orders, #hdb-abandonedCarts, #hdb-allVisits, #hdb-orderEdit, #hdb-allMarkets, #hdb-salesByTaxType {
		display: none;
	}
	
	.hdb_circles {
	display: flex;
	justify-content: center;
	}
	.hdb_circle-with-text {
	background: lightgrey;
	justify-content: center;
	align-items: center;
	border-radius: 100%;
	text-align: center;
	margin: 5px ;
	font-size: 12px;
	padding: 12px;
	display: flex;
	height: 18px;
	width: 18px;
	color: #fff;
	}
	.hdb_circleGroup {
	justify-content: center;
	align-items: center;
	text-align: center;
	margin: 5px ;
	font-size: 15px;
	padding: 5px;  
	display: flex;
	}
	.hdb_active {
	background: linear-gradient(orange, red);
	}


	
/****************popUpCellRenderer*****************/
.hdb_popUp_btn, button.hdb_popUp_btn {
  color: var(--e-global-color-primary);
  border: 1px solid var(--e-global-color-primary);
  /* background-color: #4fadff; */

  display: inline-block;
  font-weight: 400;
  line-height: 1.5;
  text-align: center;
  text-decoration: none;
  vertical-align: middle;
  cursor: pointer;
  -webkit-user-select: none;
  -ms-user-select: none;
  user-select: none;
  padding: 0.075rem 0.75rem;
  font-size: 1rem;
  border-radius: 0;
}

.hdb_popUp_btn:hover, .hdb_popUp_btn:focus, button.hdb_popUp_btn:hover, button.hdb_popUp_btn:focus {
	color: white !important;
	background-color: var(--e-global-color-primary);
}


.hdb-popup-container {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen,
    Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
  position: absolute;
  z-index: 1000;
  min-width: 60rem;
  padding: 0.5rem 0;
  margin: 0;
  color:black;
  font-size: 1rem;
  text-align: left;
  list-style: none;
  background-color: aliceblue;
  background-clip: padding-box;
  border: 1px solid aliceblue;
  border-radius: 0;
}

.hdb-popup-container h4{
	text-align: center;
}

table.hdb-popup-table {
	margin: 10px;
	table-layout:fixed;
    width:98%;
	background-color: white;
	border: none;
}

table.hdb-popup-table td {
	border: none;
}

table.hdb-popup-table tbody>tr>td, table tbody>tr>th {
	background-color: inherit;
}

.hdb-popup-table tr:hover {
  background-color: lightyellow;
}

.hdb-popup-table ol {
	padding-left: 1rem;
}

.hdb-item-list li {
	margin-top: 5px;
}


.hdb-popup-table .hdb-popup-tableH-values {
	
}

.hdb-popup-table .hdb-popup-tableH-keys {
	width:15%;
}

.hdb-popup-table td {
	padding: 5px;
}


.hdb-popup-table .hdb-table-key {
	font-weight: 500;
	text-align: right;
	text-transform: capitalize;	
}


/****************popUpCellRenderer*****************/


/************dashboard spinner******************/
#spinner {
			border: 8px solid #f3f3f3;;
			border-radius: 50%;
			border-top: 8px solid  var(--e-global-color-primary);
			width: 40px;
			height: 40px;
			display: inline-block;
			margin: 10px 20px 0 0;
		}

/* Safari */
@-webkit-keyframes spin {
	0% { -webkit-transform: rotate(0deg); }
	100% { -webkit-transform: rotate(360deg); }
}

@keyframes spin {
	0% { transform: rotate(0deg); }
	100% { transform: rotate(360deg); }
}	
.spinnerShow {
	opacity:1;
	-webkit-animation: spin 1.5s linear infinite; /* Safari */
	animation: spin 1.5s linear infinite;
}
.spinnerHide{
	opacity: 0;
}

.spinnerContainer {
	display: flex;
	margin-left: 40px;
	margin-top: 25px;
	align-items:  center;
	justify-content: end;
}
		
/************dashboard spinner******************/